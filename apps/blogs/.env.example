# ── Content source (build-time only; read by scripts/fetch-content.ts) ──
# The private/public GitHub repo holding your markdown blog folders.
CONTENT_REPO_OWNER=your-github-username
CONTENT_REPO_NAME=your-content-repo
CONTENT_REPO_BRANCH=main
# Fine-grained PAT with contents:read. Required for private repos,
# recommended for public (5000 req/hr vs 60). Leave empty for public + low volume.
GITHUB_TOKEN=

# ── Public site config (exposed to the client via Vite; VITE_ prefix) ──
VITE_SITE_NAME=Dev Blog
VITE_SITE_DESCRIPTION=A developer blog rendered from markdown.
# Absolute origin, no trailing slash. Used for canonical URLs, sitemap, RSS, OG.
VITE_SITE_ORIGIN=http://localhost:3001
# Public link to the source/content repo shown in the UI.
VITE_REPO_URL=https://github.com/your-github-username/your-content-repo
VITE_DEFAULT_OG_IMAGE=/og-default.png
VITE_AUTHOR_NAME=Your Name
VITE_AUTHOR_URL=https://example.com

# Giscus comments (https://giscus.app) — enable GitHub Discussions on the repo first
VITE_GISCUS_REPO=Shashivadan/blogs
VITE_GISCUS_REPO_ID=
VITE_GISCUS_CATEGORY=Announcements
VITE_GISCUS_CATEGORY_ID=
